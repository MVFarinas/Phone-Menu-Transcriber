# Extractor backend selection: "ollama" (default) or "hosted".
EXTRACTOR_BACKEND=ollama

# Model name for the selected backend (Ollama tag for the default backend).
EXTRACTOR_MODEL=qwen3:8b

# Base URL of the local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# Only needed if you implement and select EXTRACTOR_BACKEND=hosted.
# Never commit a real key — copy this file to .env and fill it in locally.
# HOSTED_API_KEY=
